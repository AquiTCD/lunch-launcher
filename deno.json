{
  "name": "lunch-launcher",
  "version": "1.0.0",
  "description": "Slack app for lunch matching system using Google Apps Script",
  "main": "src/index.ts",
  "scripts": {
    "build": "deno run --allow-read --allow-write build.ts",
    "push": "clasp push",
    "deploy": "deno run --allow-read --allow-write build.ts && clasp push",
    "watch": "deno run --allow-read --allow-write --watch build.ts",
    "lint": "deno lint src/",
    "fmt": "deno fmt src/",
    "check": "deno check src/**/*.ts",
    "test": "deno test --allow-read --allow-write"
  },
  "imports": {
    "@types/google-apps-script": "npm:@types/google-apps-script@^1.0.78"
  },
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"],
      "exclude": ["no-explicit-any"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-write --watch build.ts",
    "clean": "deno run --allow-read --allow-write clean.ts"
  }
}
