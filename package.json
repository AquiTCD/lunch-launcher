{
  "name": "lunch-launcher",
  "version": "1.0.0",
  "description": "Slack app for lunch matching system using Google Apps Script",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "push": "clasp push",
    "deploy": "npm run build && clasp push",
    "watch": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "slack",
    "gas",
    "typescript",
    "lunch",
    "matching"
  ],
  "author": "AquiTCD",
  "license": "MIT",
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.78",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
